{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "description": "Auto-merge internal apps within the apps/ directory",
      "matchFileNames": ["apps/**"],
      "automerge": true,
      "platformAutomerge": true,
      "automergeType": "pr",
      "matchPackageNames": [
        "ghcr.io/portfolio-solver-platform/{/,}**"
      ]
    }
  ],
  "flux": {
    "managerFilePatterns": ["/\\.yaml$/"]
  }
}
