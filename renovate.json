{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "customManagers": [
    {
      "customType": "regex",
      "description": "Find Docker images in Flux HelmRelease values (apps folder only)",
      "managerFilePatterns": [
        "/^apps/.*\\.ya?ml$/"
      ],
      "matchStrings": [
        "image:\\s+[\"']?(?<depName>ghcr\\.io/portfolio-solver-platform/[^\\s:]+):(?<currentValue>[^\\s\"']+)"
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "description": "Auto-merge internal apps within the apps/ directory",
      "matchPackagePrefixes": ["ghcr.io/portfolio-solver-platform/"],
      "matchFileNames": ["apps/**"],
      "automerge": true,
      "platformAutomerge": true,
      "automergeType": "pr"
    }
  ]
}
